{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "install",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/install",
            "args": [
                "${input:profile}"
            ],
            "group": {
                "kind": "build"
            },
            "presentation": {
                "clear": true,
            },
        },
        {
            "label": "build",
            "dependsOn": "install",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/build",
            "args": [
                "${input:profile}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/clean",
            "args": [
                "${input:profile}"
            ],
            "group": {
                "kind": "build",
            },
            "presentation": {
                "clear": true,
            },
        },
        {
            "label": "lint",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/lint",
            "group": {
                "kind": "test",
            },
            "presentation": {
                "clear": true,
            },
        },
        {
            "label": "test",
            "dependsOn": "build",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/test",
            "args": [
                "${input:profile}"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
        },
    ],
    "inputs": [
        {
            "id": "profile",
            "type": "pickString",
            "description": "Conan profile",
            "options": [
                "clang-debug",
                "clang-release",
                "clang-test",
                "clang-test-fuzzer",
                "clang-test-tsan",
                "clang-tidy",
                "gcc-debug",
                "gcc-release",
                "gcc-test"
            ]
        }
    ]
}
