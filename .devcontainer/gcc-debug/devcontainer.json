// built with GCC; optimized for debugging
{
    "name": "GCC debug",
    "build": {
        "dockerfile": "${localWorkspaceFolder}/.devcontainer/Dockerfile",
        "args": {
            "profile": "gcc-debug"
        },
        "context": "${localWorkspaceFolder}",
        "options": ["--progress=plain"]
    },
    "remoteUser": "tux",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools"
            ]
        }
    }
}
