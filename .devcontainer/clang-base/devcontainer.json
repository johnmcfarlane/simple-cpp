// image with Clang nightly build
{
	"name": "Clang base image",
	"build": {
		"dockerfile": "${localWorkspaceFolder}/.devcontainer/clang-base/Dockerfile",
		"context": "${localWorkspaceFolder}"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.cmake-tools",
				"ms-vscode.cpptools"
			]
		}
	}
}
