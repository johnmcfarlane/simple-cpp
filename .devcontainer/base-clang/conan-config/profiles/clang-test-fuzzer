include(default)

[settings]
build_type=Release
compiler.cppstd=26
compiler.libcxx=libstdc++

[conf]
!&:tools.build:cxxflags=["-D_GLIBCXX_ASSERTIONS=1", "-fno-sanitize-recover=all", "-fsanitize=address,fuzzer-no-link,undefined"]
&:tools.build:cxxflags=["-D_GLIBCXX_ASSERTIONS=1", "-fno-sanitize-recover=all", "-fsanitize=address,fuzzer-no-link,undefined", "-g", "-Wall", "-Werror", "-Wextra"]

[buildenv]
FUZZER_CXX_FLAGS=-fsanitize=address,fuzzer,undefined

[tool_requires]
fmt/*:cmake/[~4.2]
