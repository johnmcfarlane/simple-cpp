[settings]
arch=x86_64
build_type=Release
compiler=clang
compiler.cppstd=26
compiler.libcxx=libc++
compiler.version=22
os=Linux

[conf]
!&:tools.build:cxxflags=["-D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_DEBUG", "-fdiagnostics-color=always", "-fno-sanitize-recover=all", "-fsanitize=address,undefined"]
&:tools.build:cxxflags=["-D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_DEBUG", "-fdiagnostics-color=always", "-fno-sanitize-recover=all", "-fsanitize=address,undefined", "-g", "-Wall", "-Werror", "-Wextra"]

[tool_requires]
fmt/*:cmake/[~4.3]
