// built with Clang; optimized for debugging
{
    "name": "Clang debug",
    "build": {
        "dockerfile": "${localWorkspaceFolder}/.devcontainer/Dockerfile",
        "args": {
            "base_image": "base-clang",
            "base_image_version": "2026-03-31",
            "profile": "clang-debug"
        },
        "context": "${localWorkspaceFolder}",
        "options": ["--progress=plain"]
    },
    "remoteUser": "tux",
    "postCreateCommand": {
        "configure build system": [
            "cmake",
            "--toolchain", "/home/tux/build/conan_toolchain.cmake",
            "-B", "/home/tux/build",
            "-DCMAKE_BUILD_TYPE=Debug",
            "-DCMAKE_PREFIX_PATH=/home/tux/build",
            "-G", "Ninja",
            "-S", "${localEnv:PROJECT_SUBDIRECTORY:.}"
        ]
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools"
            ]
        }
    }
}
