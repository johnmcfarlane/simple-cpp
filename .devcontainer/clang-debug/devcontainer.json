// built with Clang; optimized for debugging
{
    "name": "Clang debug",
    "build": {
        "dockerfile": "${localWorkspaceFolder}/.devcontainer/Dockerfile",
        "args": {
            "base_image": "base-clang",
            "base_image_version": "2026-04-03",
            "profile": "clang-debug"
        },
        "context": "${localWorkspaceFolder}",
        "options": ["--progress=plain"]
    },
    "remoteUser": "tux",
    "postCreateCommand": {
        "configure build system": "cmake --toolchain $BUILD_DIR/conan_toolchain.cmake -B $BUILD_DIR -DCMAKE_BUILD_TYPE=Debug -DCMAKE_CXX_STDLIB_MODULES_JSON=/usr/lib/llvm-23/lib/libc++.modules.json -DCMAKE_PREFIX_PATH=$BUILD_DIR -G Ninja -S ${localEnv:PROJECT_SUBDIRECTORY:.}"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools"
            ]
        }
    }
}
