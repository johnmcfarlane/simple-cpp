include(default)

[settings]
build_type=Release
compiler.cppstd=26

[conf]
!&:tools.build:cxxflags=["-D_GLIBCXX_ASSERTIONS=1", "-fno-sanitize-recover=all", "-fsanitize=address,undefined"]
&:tools.build:cxxflags=["-D_GLIBCXX_ASSERTIONS=1", "-fno-sanitize-recover=all", "-fsanitize=address,undefined", "-g", "-Wall", "-Werror", "-Wextra"]

[tool_requires]
fmt/*:cmake/[~4.3]
