// image with GCC trunk build
{
	"name": "GCC base image",
	"build": {
		"dockerfile": "${localWorkspaceFolder}/.devcontainer/gcc-base/Dockerfile",
		"context": "${localWorkspaceFolder}"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.cmake-tools",
				"ms-vscode.cpptools"
			]
		}
	}
}
