// built with Clang; analyzed with Clang-Tidy
{
    "name": "Clang-Tidy",
    "build": {
        "dockerfile": "${localWorkspaceFolder}/.devcontainer/Dockerfile",
        "args": {
            "profile": "clang-tidy"
        },
        "context": "${localWorkspaceFolder}",
        "options": ["--progress=plain"]
    },
    "remoteUser": "tux",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools"
            ]
        }
    }
}
