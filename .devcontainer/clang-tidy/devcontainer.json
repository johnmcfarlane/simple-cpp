// built with Clang; analyzed with Clang-Tidy
{
    "name": "Clang-Tidy",
    "build": {
        "dockerfile": "${localWorkspaceFolder}/.devcontainer/clang-tidy/Dockerfile",
        "context": "${localWorkspaceFolder}"
    },
    "remoteUser": "root",
    "postCreateCommand": {
        "prep-build-dir": [
            "cmake",
            "--toolchain", "${containerEnv:BUILD_DIR}/conan_toolchain.cmake",
            "-B", "${containerEnv:BUILD_DIR}",
            "-DCMAKE_BUILD_TYPE=Release",
            "-DCMAKE_PREFIX_PATH=${containerEnv:BUILD_DIR}",
            "-G", "Ninja",
            "-S", ".",
            "-DCMAKE_CXX_STDLIB_MODULES_JSON=/usr/lib/llvm-22/lib/libc++.modules.json",
            "-DCMAKE_CXX_CLANG_TIDY=clang-tidy"
        ]
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools"
            ]
        }
    }
}
