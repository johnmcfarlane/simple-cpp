[settings]
arch=x86_64
build_type=Release
compiler=gcc
compiler.cppstd=26
compiler.libcxx=libstdc++
compiler.version=16
os=Linux

[buildenv]
CXX=g++

[conf]
!&:tools.build:cxxflags=["-D_GLIBCXX_ASSERTIONS=1", "-fdiagnostics-color=always", "-fno-sanitize-recover=all", "-fsanitize=address,undefined"]
&:tools.build:cxxflags=["-D_GLIBCXX_ASSERTIONS=1", "-fdiagnostics-color=always", "-fno-sanitize-recover=all", "-fsanitize=address,undefined", "-g", "-Wall", "-Werror", "-Wextra"]

[tool_requires]
fmt/*:cmake/[~4.3]
