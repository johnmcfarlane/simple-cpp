[settings]
arch=x86_64
build_type=Debug
compiler=clang
compiler.cppstd=26
compiler.libcxx=libc++
compiler.sanitizer=ThreadUndefinedBehavior
compiler.version=22
os=Linux

[buildenv]
CXX=clang++

[conf]
!&:tools.build:cxxflags=["-fdiagnostics-color=always", "-fno-sanitize-recover=all", "-fsanitize=thread,undefined"]
&:tools.build:cxxflags=["-fdiagnostics-color=always", "-fno-sanitize-recover=all", "-fsanitize=thread,undefined", "-g", "-Wall", "-Werror", "-Wextra"]

[tool_requires]
fmt/*:cmake/[~4.3]
