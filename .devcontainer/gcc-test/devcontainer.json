// built with GCC; optimized for testing
{
	"name": "GCC test",
	"build": {
		"dockerfile": "${localWorkspaceFolder}/.devcontainer/gcc-test/Dockerfile",
		"context": "${localWorkspaceFolder}"
	},
    "postCreateCommand": {
        "prep-build-dir": [
            "cmake",
            "--toolchain", "${containerEnv:BUILD_DIR}/conan_toolchain.cmake",
            "-B", "${containerEnv:BUILD_DIR}",
            "-DCMAKE_BUILD_TYPE=Release",
            "-DCMAKE_PREFIX_PATH=${containerEnv:BUILD_DIR}",
            "-G", "Ninja",
            "-S", "."
        ]
    },
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.cmake-tools",
				"ms-vscode.cpptools"
			]
		}
	}
}
