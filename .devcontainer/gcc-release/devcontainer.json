// built with GCC; optimized for production
{
    "name": "GCC release",
    "build": {
        "dockerfile": "${localWorkspaceFolder}/.devcontainer/Dockerfile",
        "args": {
            "base_image": "base-gcc",
            "base_image_version": "5a166514951",
            "profile": "gcc-release"
        },
        "context": "${localWorkspaceFolder}",
        "options": ["--progress=plain"]
    },
    "postCreateCommand": {
        "configure build system": [
            "cmake",
            "--toolchain", "/home/tux/build/conan_toolchain.cmake",
            "-B", "/home/tux/build",
            "-DCMAKE_BUILD_TYPE=Release",
            "-DCMAKE_PREFIX_PATH=/home/tux/build",
            "-G", "Ninja",
            "-S", "${localEnv:PROJECT_SUBDIRECTORY:.}"
        ]
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools"
            ]
        }
    }
}
