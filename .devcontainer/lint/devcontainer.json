// check formatting
{
    "name": "Lint",
    "build": {
        "dockerfile": "${localWorkspaceFolder}/.devcontainer/Dockerfile",
        "args": {
            "base_image": "base-clang",
            "base_image_version": "2026-04-02",
            "profile": "clang-release"
        },
        "context": "${localWorkspaceFolder}",
        "options": ["--progress=plain"]
    },
    "remoteUser": "tux",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools"
            ]
        }
    }
}
