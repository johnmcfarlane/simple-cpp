[settings]
arch=x86_64
build_type=Debug
compiler=clang
compiler.cppstd=26
compiler.libcxx=libc++
compiler.version=22
os=Linux

[buildenv]
CXX=clang++

[conf]
!&:tools.build:cxxflags=["-fdiagnostics-color=always", "-fno-sanitize-recover=all", "-fsanitize=thread"]
&:tools.build:cxxflags=["-fdiagnostics-color=always", "-fno-sanitize-recover=all", "-fsanitize=thread", "-g", "-Wall", "-Werror", "-Wextra"]
&:tools.cmake.cmaketoolchain:extra_variables={"CMAKE_BUILD_TYPE": "Debug"}

[tool_requires]
fmt/*:cmake/[~4.3]
